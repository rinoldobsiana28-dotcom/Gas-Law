```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Understanding the Laws of Gases | Interactive Visual Guide</title>

<style>

body{
    font-family:Arial,sans-serif;
    max-width:1000px;
    margin:auto;
    padding:20px;
    line-height:1.6;
    background:#f5f5f5;
}

h1{
    text-align:center;
}

section{
    background:white;
    border:2px solid #444;
    border-radius:12px;
    padding:20px;
    margin:30px 0;
    text-align:center;
}

canvas{
    border:2px solid #222;
    background:white;
    display:block;
    margin:auto;
    max-width:100%;
}

.slider{
    width:300px;
    margin:10px;
}

button{
    padding:10px 20px;
    cursor:pointer;
}

.info{
    font-weight:bold;
    margin-top:10px;
}

</style>
</head>

<body>

<h1>Understanding the Laws of Gases: Interactive Visual Guide</h1>

<p>
Explore how gases behave through live simulations of Boyle's Law,
Charles's Law, Gay-Lussac's Law, and Avogadro's Law.
</p>

<!-- Boyle -->

<section>

<h2>Boyle's Law</h2>

<p>
At constant temperature, decreasing volume increases pressure.
</p>

<input type="range"
id="piston"
class="slider"
min="50"
max="180"
value="50">

<br>

<canvas id="boyle" width="600" height="300"></canvas>

<div class="info" id="pressureText">
Pressure: 1.00 atm
</div>

</section>

<!-- Charles -->

<section>

<h2>Charles's Law</h2>

<p>
At constant pressure, increasing temperature increases volume.
</p>

<input type="range"
id="balloonSlider"
class="slider"
min="1"
max="2"
step="0.01"
value="1">

<br>

<canvas id="charles" width="600" height="300"></canvas>

<div class="info">
Move slider to increase temperature
</div>

</section>

<!-- Gay-Lussac -->

<section>

<h2>Gay-Lussac's Law</h2>

<p>
At constant volume, increasing temperature increases pressure.
</p>

<input type="range"
id="speedSlider"
class="slider"
min="1"
max="8"
value="2">

<br>

<canvas id="gay" width="600" height="300"></canvas>

<div class="info" id="tempDisplay">
Temperature Level: 2
</div>

</section>

<!-- Avogadro -->

<section>

<h2>Avogadro's Law</h2>

<p>
Adding more gas particles increases volume.
</p>

<button id="addGas">
Add Gas Particle
</button>

<br><br>

<canvas id="avo" width="600" height="300"></canvas>

<div class="info" id="particleCount">
Particles: 10
</div>

</section>

<script>

/* ======================================
   BOYLE'S LAW
====================================== */

const b=document.getElementById("boyle");
const bctx=b.getContext("2d");

const piston=document.getElementById("piston");

let boyleParticles=[];

for(let i=0;i<30;i++){

    boyleParticles.push({

        x:80+Math.random()*340,
        y:100+Math.random()*100,

        vx:(Math.random()-0.5)*2,
        vy:(Math.random()-0.5)*2

    });

}

function drawBoyle(){

    const pistonY=Number(piston.value);

    bctx.clearRect(0,0,600,300);

    bctx.strokeRect(100,20,400,220);

    bctx.fillStyle="gray";
    bctx.fillRect(100,pistonY,400,15);

    const chamberTop=pistonY+15;
    const chamberBottom=240;

    boyleParticles.forEach(p=>{

        p.x+=p.vx;
        p.y+=p.vy;

        if(p.x<105 || p.x>495){
            p.vx*=-1;
        }

        if(p.y<chamberTop+5){

            p.y=chamberTop+5;
            p.vy*=-1;

        }

        if(p.y>chamberBottom-5){

            p.y=chamberBottom-5;
            p.vy*=-1;

        }

        bctx.beginPath();
        bctx.arc(p.x,p.y,4,0,Math.PI*2);
        bctx.fillStyle="blue";
        bctx.fill();

    });

    let volume=chamberBottom-chamberTop;

    let pressure=(200/volume).toFixed(2);

    document.getElementById("pressureText").innerHTML=
    "Pressure: "+pressure+" atm";

    requestAnimationFrame(drawBoyle);

}

drawBoyle();

/* ======================================
   CHARLES'S LAW
====================================== */

const c=document.getElementById("charles");
const cctx=c.getContext("2d");

const balloonSlider=
document.getElementById("balloonSlider");

function drawCharles(){

    cctx.clearRect(0,0,600,300);

    let scale=
    Number(balloonSlider.value);

    cctx.save();

    cctx.translate(300,150);

    cctx.scale(scale,scale);

    cctx.beginPath();

    cctx.arc(0,0,60,0,Math.PI*2);

    cctx.fillStyle="skyblue";

    cctx.fill();

    cctx.restore();

    requestAnimationFrame(drawCharles);

}

drawCharles();

/* ======================================
   GAY-LUSSAC'S LAW
====================================== */

const g=document.getElementById("gay");
const gctx=g.getContext("2d");

const speedSlider=
document.getElementById("speedSlider");

let movers=[];

for(let i=0;i<25;i++){

    movers.push({

        x:Math.random()*600,
        y:Math.random()*300,

        vx:2,
        vy:2

    });

}

function drawGay(){

    let speed=
    Number(speedSlider.value);

    document.getElementById("tempDisplay")
    .innerHTML=
    "Temperature Level: "+speed;

    gctx.clearRect(0,0,600,300);

    gctx.strokeRect(20,20,560,260);

    movers.forEach(m=>{

        m.x+=m.vx*speed*0.2;
        m.y+=m.vy*speed*0.2;

        if(m.x<20 || m.x>580){

            m.vx*=-1;

        }

        if(m.y<20 || m.y>280){

            m.vy*=-1;

        }

        gctx.beginPath();

        gctx.arc(m.x,m.y,4,0,Math.PI*2);

        gctx.fillStyle="red";

        gctx.fill();

    });

    requestAnimationFrame(drawGay);

}

drawGay();

/* ======================================
   AVOGADRO'S LAW
====================================== */

const a=document.getElementById("avo");
const actx=a.getContext("2d");

let gas=[];

for(let i=0;i<10;i++){

    gas.push({

        x:50+Math.random()*200,
        y:60+Math.random()*120

    });

}

document.getElementById("addGas")
.addEventListener("click",function(){

    gas.push({

        x:50+Math.random()*300,
        y:60+Math.random()*120

    });

});

function drawAvo(){

    actx.clearRect(0,0,600,300);

    const volumeWidth=
    250 + gas.length*5;

    actx.strokeRect(
        50,
        60,
        volumeWidth,
        150
    );

    gas.forEach(p=>{

        if(p.x>volumeWidth+40){

            p.x=volumeWidth+30;

        }

        actx.beginPath();

        actx.arc(
            p.x,
            p.y,
            4,
            0,
            Math.PI*2
        );

        actx.fillStyle="green";

        actx.fill();

    });

    document.getElementById("particleCount")
    .innerHTML=
    "Particles: "+gas.length;

    requestAnimationFrame(drawAvo);

}

drawAvo();

</script>

</body>
</html>
```
